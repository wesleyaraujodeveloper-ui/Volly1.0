{
  "expo": {
    "name": "Volly Connect",
    "slug": "vollyconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/icone-volly-logo.png",
    "scheme": "vollyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "O Volly precisa de acesso à câmera para você tirar fotos para o mural.",
        "NSMicrophoneUsageDescription": "O Volly precisa de acesso ao microfone para recursos de áudio.",
        "NSContactsUsageDescription": "O Volly precisa de acesso aos contatos para facilitar o convite de voluntários.",
        "NSLocationWhenInUseUsageDescription": "O Volly usa sua localização para sugerir eventos próximos.",
        "NSPhotoLibraryUsageDescription": "O Volly precisa de acesso às suas fotos para você compartilhar no mural.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.wesleydeveloper.volly"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/icons/icone-volly-logo.png"
      },
      "package": "com.wesleydeveloper.volly",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icons/icone-volly-logo.png",
      "name": "Volly Connect",
      "shortName": "Volly",
      "themeColor": "#121212",
      "backgroundColor": "#121212"
    },
    "notification": {
      "icon": "./assets/images/icons/icone-volly-logo.png",
      "color": "#121212",
      "vapidPublicKey": "BMzKLdhLcF5qAzLy9BIIDC5miXslc1udM_NchdeH40TxHc7z5KEOzE7AFRCpW_SmEoBn_QF9BjewK5ARMweVXrQ",
      "serviceWorkerPath": "/expo-service-worker.js"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o Volly acesse suas fotos para compartilhar no mural.",
          "cameraPermission": "Permitir que o Volly use sua câmera para tirar fotos para o mural."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2098baaa-76e9-4341-a434-cea69d5d6fa4"
      }
    },
    "owner": "wesleyaraujo"
  }
}
