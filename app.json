{
  "expo": {
    "name": "Volly",
    "slug": "volly-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/volly-logo.png",
    "scheme": "vollyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "O Volly precisa de acesso à câmera para você tirar fotos para o mural.",
        "NSMicrophoneUsageDescription": "O Volly precisa de acesso ao microfone para recursos de áudio.",
        "NSContactsUsageDescription": "O Volly precisa de acesso aos contatos para facilitar o convite de voluntários.",
        "NSLocationWhenInUseUsageDescription": "O Volly usa sua localização para sugerir eventos próximos.",
        "NSPhotoLibraryUsageDescription": "O Volly precisa de acesso às suas fotos para você compartilhar no mural."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/icons/volly-logo.png"
      },
      "package": "com.wesleydeveloper.volly",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icons/volly-logo.png",
      "name": "Volly App",
      "shortName": "Volly",
      "themeColor": "#121212",
      "backgroundColor": "#121212"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o Volly acesse suas fotos para compartilhar no mural.",
          "cameraPermission": "Permitir que o Volly use sua câmera para tirar fotos para o mural."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
